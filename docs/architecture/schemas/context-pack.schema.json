{
  "$defs": {
    "ArtifactLocation": {
      "additionalProperties": false,
      "properties": {
        "commit_sha": {
          "title": "Commit Sha",
          "type": "string"
        },
        "path": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "ref": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "repository_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Repository Id",
          "type": "string"
        }
      },
      "required": [
        "repository_id",
        "ref",
        "commit_sha",
        "path"
      ],
      "title": "ArtifactLocation",
      "type": "object"
    },
    "ArtifactVersionRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Kind",
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_id",
        "version",
        "sha256",
        "kind"
      ],
      "title": "ArtifactVersionRef",
      "type": "object"
    },
    "ContextEntry": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "entry_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Entry Id",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "source_ref": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Source Ref",
          "type": "string"
        },
        "title": {
          "maxLength": 300,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entry_id",
        "version",
        "sha256",
        "title",
        "content",
        "source_ref"
      ],
      "title": "ContextEntry",
      "type": "object"
    },
    "RequiredOutput": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Kind",
          "type": "string"
        },
        "output_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Output Id",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "schema_uri": {
          "anyOf": [
            {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Uri"
        }
      },
      "required": [
        "output_id",
        "kind"
      ],
      "title": "RequiredOutput",
      "type": "object"
    },
    "RunBudget": {
      "additionalProperties": false,
      "properties": {
        "max_cost_usd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Cost Usd"
        },
        "max_model_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Model Tokens"
        },
        "max_output_bytes": {
          "default": 1000000,
          "maximum": 50000000,
          "minimum": 1024,
          "title": "Max Output Bytes",
          "type": "integer"
        },
        "max_seconds": {
          "maximum": 86400,
          "minimum": 1,
          "title": "Max Seconds",
          "type": "integer"
        }
      },
      "required": [
        "max_seconds"
      ],
      "title": "RunBudget",
      "type": "object"
    },
    "StageContract": {
      "additionalProperties": false,
      "properties": {
        "completion_conditions": {
          "items": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 100,
          "minItems": 1,
          "title": "Completion Conditions",
          "type": "array"
        },
        "contract_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Contract Id",
          "type": "string"
        },
        "objective": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Objective",
          "type": "string"
        },
        "title": {
          "maxLength": 300,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "contract_id",
        "title",
        "objective",
        "completion_conditions"
      ],
      "title": "StageContract",
      "type": "object"
    }
  },
  "$id": "https://agora.local/schemas/v1/context-pack.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "budget": {
      "$ref": "#/$defs/RunBudget"
    },
    "content_sha256": {
      "title": "Content Sha256",
      "type": "string"
    },
    "forbidden_constraints": {
      "items": {
        "maxLength": 20000,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 100,
      "title": "Forbidden Constraints",
      "type": "array"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "input_artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactVersionRef"
      },
      "maxItems": 200,
      "title": "Input Artifacts",
      "type": "array"
    },
    "pack_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Pack Id",
      "type": "string"
    },
    "policies": {
      "items": {
        "$ref": "#/$defs/ContextEntry"
      },
      "maxItems": 100,
      "title": "Policies",
      "type": "array"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "project_knowledge": {
      "items": {
        "$ref": "#/$defs/ContextEntry"
      },
      "maxItems": 100,
      "title": "Project Knowledge",
      "type": "array"
    },
    "required_outputs": {
      "items": {
        "$ref": "#/$defs/RequiredOutput"
      },
      "maxItems": 100,
      "title": "Required Outputs",
      "type": "array"
    },
    "run_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^1\\.[0-9]+$",
      "title": "Schema Version",
      "type": "string"
    },
    "stage_contract": {
      "$ref": "#/$defs/StageContract"
    },
    "stage_key": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Stage Key",
      "type": "string"
    },
    "task_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Task Id",
      "type": "string"
    },
    "task_memory": {
      "items": {
        "$ref": "#/$defs/ContextEntry"
      },
      "maxItems": 100,
      "title": "Task Memory",
      "type": "array"
    },
    "user_preferences": {
      "items": {
        "$ref": "#/$defs/ContextEntry"
      },
      "maxItems": 50,
      "title": "User Preferences",
      "type": "array"
    }
  },
  "required": [
    "content_sha256",
    "pack_id",
    "project_id",
    "task_id",
    "stage_key",
    "run_id",
    "generated_at",
    "stage_contract",
    "budget"
  ],
  "title": "ContextPack",
  "type": "object"
}
