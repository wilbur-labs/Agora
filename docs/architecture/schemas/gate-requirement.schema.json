{
  "$defs": {
    "RequirementSeverity": {
      "enum": [
        "blocker",
        "warning"
      ],
      "title": "RequirementSeverity",
      "type": "string"
    }
  },
  "$id": "https://agora.local/schemas/v1/gate-requirement.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "commit_sha": {
      "title": "Commit Sha",
      "type": "string"
    },
    "evidence_kind": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Evidence Kind",
      "type": "string"
    },
    "failure_action": {
      "maxLength": 20000,
      "minLength": 1,
      "title": "Failure Action",
      "type": "string"
    },
    "priority": {
      "default": 100,
      "maximum": 10000,
      "minimum": 0,
      "title": "Priority",
      "type": "integer"
    },
    "ref": {
      "maxLength": 20000,
      "minLength": 1,
      "title": "Ref",
      "type": "string"
    },
    "repository_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Repository Id",
      "type": "string"
    },
    "requirement_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Requirement Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^1\\.[0-9]+$",
      "title": "Schema Version",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/RequirementSeverity",
      "default": "blocker"
    },
    "title": {
      "maxLength": 300,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "requirement_id",
    "title",
    "repository_id",
    "ref",
    "commit_sha",
    "evidence_kind",
    "failure_action"
  ],
  "title": "GateRequirement",
  "type": "object"
}
