{
  "$defs": {
    "ArtifactLocation": {
      "additionalProperties": false,
      "properties": {
        "commit_sha": {
          "title": "Commit Sha",
          "type": "string"
        },
        "path": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "ref": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "repository_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Repository Id",
          "type": "string"
        }
      },
      "required": [
        "repository_id",
        "ref",
        "commit_sha",
        "path"
      ],
      "title": "ArtifactLocation",
      "type": "object"
    },
    "ArtifactStorage": {
      "enum": [
        "managed",
        "referenced"
      ],
      "title": "ArtifactStorage",
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Run Id",
          "type": "string"
        },
        "runtime": {
          "$ref": "#/$defs/RuntimeName"
        },
        "stage_key": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Stage Key",
          "type": "string"
        }
      },
      "required": [
        "runtime",
        "run_id",
        "stage_key"
      ],
      "title": "ProducerRef",
      "type": "object"
    },
    "RuntimeName": {
      "enum": [
        "agora",
        "codex",
        "claude",
        "kiro"
      ],
      "title": "RuntimeName",
      "type": "string"
    }
  },
  "$id": "https://agora.local/schemas/v1/artifact.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Artifact Id",
      "type": "string"
    },
    "content": {
      "anyOf": [
        {
          "maxLength": 2000000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "kind": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Kind",
      "type": "string"
    },
    "location": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactLocation"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "media_type": {
      "default": "text/plain",
      "maxLength": 255,
      "minLength": 1,
      "title": "Media Type",
      "type": "string"
    },
    "producer": {
      "$ref": "#/$defs/ProducerRef"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^1\\.[0-9]+$",
      "title": "Schema Version",
      "type": "string"
    },
    "sha256": {
      "title": "Sha256",
      "type": "string"
    },
    "stage_key": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Stage Key",
      "type": "string"
    },
    "storage": {
      "$ref": "#/$defs/ArtifactStorage"
    },
    "task_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Task Id",
      "type": "string"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "artifact_id",
    "project_id",
    "task_id",
    "stage_key",
    "producer",
    "kind",
    "storage",
    "version",
    "sha256",
    "created_at"
  ],
  "title": "Artifact",
  "type": "object"
}
