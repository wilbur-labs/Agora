{
  "$defs": {
    "ApprovalArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "commit_sha": {
          "title": "Commit Sha",
          "type": "string"
        },
        "path": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "ref": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "repository_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "title": "Repository Id",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "repository_id",
        "ref",
        "commit_sha",
        "path",
        "sha256"
      ],
      "title": "ApprovalArtifactBinding",
      "type": "object"
    },
    "ApprovalStatus": {
      "enum": [
        "active",
        "stale",
        "revoked"
      ],
      "title": "ApprovalStatus",
      "type": "string"
    }
  },
  "$id": "https://agora.local/schemas/v1/approval.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approval_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Approval Id",
      "type": "string"
    },
    "approved_at": {
      "format": "date-time",
      "title": "Approved At",
      "type": "string"
    },
    "approved_by": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Approved By",
      "type": "string"
    },
    "artifact_versions": {
      "items": {
        "$ref": "#/$defs/ApprovalArtifactBinding"
      },
      "maxItems": 100,
      "minItems": 1,
      "title": "Artifact Versions",
      "type": "array"
    },
    "commit_sha": {
      "title": "Commit Sha",
      "type": "string"
    },
    "gate_key": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Gate Key",
      "type": "string"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "ref": {
      "maxLength": 20000,
      "minLength": 1,
      "title": "Ref",
      "type": "string"
    },
    "repository_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Repository Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^1\\.[0-9]+$",
      "title": "Schema Version",
      "type": "string"
    },
    "stage_key": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Stage Key",
      "type": "string"
    },
    "stale_reason": {
      "anyOf": [
        {
          "maxLength": 4000,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Stale Reason"
    },
    "status": {
      "$ref": "#/$defs/ApprovalStatus",
      "default": "active"
    },
    "task_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Task Id",
      "type": "string"
    }
  },
  "required": [
    "approval_id",
    "project_id",
    "task_id",
    "stage_key",
    "gate_key",
    "repository_id",
    "ref",
    "commit_sha",
    "artifact_versions",
    "approved_by",
    "approved_at"
  ],
  "title": "Approval",
  "type": "object"
}
