{
  "$defs": {
    "ProcessStatus": {
      "enum": [
        "pending",
        "running",
        "exited",
        "launch_failed",
        "timed_out",
        "cancelled",
        "interrupted"
      ],
      "title": "ProcessStatus",
      "type": "string"
    },
    "SchemaStatus": {
      "enum": [
        "pending",
        "valid",
        "repaired",
        "protocol_failed"
      ],
      "title": "SchemaStatus",
      "type": "string"
    },
    "SemanticStageResult": {
      "enum": [
        "pending",
        "succeeded",
        "blocked",
        "failed",
        "cancelled"
      ],
      "title": "SemanticStageResult",
      "type": "string"
    },
    "TransportStatus": {
      "enum": [
        "pending",
        "connected",
        "completed",
        "failed"
      ],
      "title": "TransportStatus",
      "type": "string"
    }
  },
  "$id": "https://agora.local/schemas/v1/run-protocol-state.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "process_exit_code": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Process Exit Code"
    },
    "process_status": {
      "$ref": "#/$defs/ProcessStatus"
    },
    "repair_attempts": {
      "default": 0,
      "maximum": 1,
      "minimum": 0,
      "title": "Repair Attempts",
      "type": "integer"
    },
    "run_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_status": {
      "$ref": "#/$defs/SchemaStatus"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^1\\.[0-9]+$",
      "title": "Schema Version",
      "type": "string"
    },
    "semantic_stage_result": {
      "$ref": "#/$defs/SemanticStageResult"
    },
    "transport_status": {
      "$ref": "#/$defs/TransportStatus"
    }
  },
  "required": [
    "run_id",
    "process_status",
    "transport_status",
    "schema_status",
    "semantic_stage_result"
  ],
  "title": "RunProtocolState",
  "type": "object"
}
