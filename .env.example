# Agora Environment Variables
# Copy this to .env and fill in your values

# === Required: at least one model provider ===

# Azure OpenAI (recommended for function calling)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...

# DeepSeek (alternative, good for code)
# DEEPSEEK_API_KEY=

# === Optional ===

# Web search (future)
# TAVILY_API_KEY=
