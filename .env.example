# Agora Environment Variables
# Copy this to .env and fill in your values

# === Model Providers ===
# Configure one or more. Each agent can use a different provider.
# See config.yaml to assign models to specific agents.

# Azure OpenAI (recommended for function calling + streaming)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com

# OpenAI API (alternative)
# OPENAI_API_KEY=sk-...

# Kiro CLI (headless mode, requires kiro-cli installed)
# KIRO_API_KEY=ksk_...

# DeepSeek (OpenAI-compatible)
# DEEPSEEK_API_KEY=

# === Optional ===

# Embedding (for semantic skill matching)
# Uses same Azure OpenAI credentials above, configure in config.yaml

# Web search (future)
# TAVILY_API_KEY=
