# Agora Environment Variables
# Copy this file to .env and fill in the providers you want to use.
#
# Default config.yaml uses Claude for execution (tool-calling) and Azure OpenAI
# for discussion agents. You can change this in config.yaml — each agent can
# use a different provider.

# === Recommended setup ===

# Anthropic Claude — best tool-calling quality, used as default executor.
CLAUDE_API_KEY=

# Azure OpenAI — used for discussion agents (scout / architect / critic).
# Strong enterprise choice; stable, compliant, fast.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com

# === Alternatives (edit config.yaml to switch) ===

# OpenAI direct (if you don't have Azure access)
# OPENAI_API_KEY=sk-...

# DeepSeek (OpenAI-compatible, low cost)
# DEEPSEEK_API_KEY=

# Kiro CLI (headless mode, requires kiro-cli installed)
# KIRO_API_KEY=ksk_...

# === Optional ===

# Embedding provider for semantic skill matching & memory retrieval.
# Reuses Azure OpenAI credentials by default — enable in config.yaml.

# Web search (future)
# TAVILY_API_KEY=
